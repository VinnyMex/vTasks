{
  "manifest_version": 3,
  "name": "vTasks: Notas e Tarefas vWeb",
  "description": "Organize suas ideias e projetos com rapidez usando vTasks.",
  "version": "0.6.1",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "storage",
    "sidePanel",
    "windows"
  ]
}
